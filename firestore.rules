rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // For prototype, we allow reads for everyone and writes for authenticated users.
    // In production, you would check admin claims or a specific users collection.
    
    match /kemenag_news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_agendas/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_announcements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_photos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_navigation/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /kemenag_allowed_users/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /kemenag_layanan_data/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
