rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // For prototype, we allow reads for everyone and writes for authenticated users.
    // In production, you would check admin claims or a specific users collection.
    
    match /news/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /agendas/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /photos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /videos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /navigation/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /allowed_users/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /layanan_data/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
